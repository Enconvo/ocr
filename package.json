{
  "$schema": "https://enconvo.com/schemas/extension.json",
  "name": "ocr_action",
  "version": "0.0.138",
  "description": "OCR commands for extracting text from images and screenshots, with silent clipboard copy and interactive SmartBar display modes.",
  "title": "OCR",
  "icon": "icon.png",
  "author": "EnconvoAI",
  "categories": [
    "OCR"
  ],
  "group": "ocr",
  "license": "MIT",
  "type": "module",
  "commands": [
    {
      "name": "ocr",
      "title": "OCR",
      "description": "Convert image to text",
      "icon": "icon.png",
      "mode": "no-view",
      "parameters": {
        "type": "object",
        "properties": {
          "context_files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Context files"
          },
          "image_files": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Image file paths for OCR, supports file:// protocol"
            },
            "description": "Image files for OCR"
          }
        }
      },
      "preferences": [
        {
          "name": "ocr_providers",
          "description": "The OCR provider to use.",
          "type": "provider",
          "providerCategory": "ocr",
          "required": false,
          "default": "default",
          "title": "OCR Provider"
        }
      ]
    },
    {
      "name": "silent_screenshot_ocr",
      "title": "Silent Screenshot OCR",
      "description": "Select the screen area for OCR and copy the OCR results to the clipboard.",
      "icon": "icon.png",
      "mode": "no-view",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "preferences": [
        {
          "name": "ocr_providers",
          "description": "The OCR provider to use.",
          "type": "provider",
          "providerCategory": "ocr",
          "required": false,
          "default": "default",
          "title": "OCR Provider"
        },
        {
          "name": "window_mode",
          "type": "dropdown",
          "title": "Window Mode",
          "description": "The window mode of the SmartBar.",
          "default": "mini_smart_bar",
          "dataProxy": "window|window_modes",
          "visibility": "hidden"
        },
        {
          "name": "bring_window_to_front",
          "type": "checkbox",
          "title": "Bring Window to Front",
          "description": "Whether to bring the window to front.",
          "default": false,
          "visibility": "hidden"
        },
        {
          "name": "hotkey",
          "description": "The hotkey used to trigger the command",
          "type": "hotkey",
          "required": false,
          "default": {
            "hotkey": "Option+S",
            "hotkey_mode": "normal"
          },
          "title": "Hotkey"
        }
      ]
    },
    {
      "name": "screenshot_ocr",
      "title": "Screenshot OCR",
      "description": "Select the screen area for OCR and show the OCR results in a smartbar window.",
      "icon": "icon.png",
      "mode": "no-view",
      "runInBackground": true,
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "preferences": [
        {
          "name": "ocr_providers",
          "description": "The OCR provider to use.",
          "type": "provider",
          "providerCategory": "ocr",
          "required": false,
          "default": "default",
          "title": "OCR Provider"
        }
      ]
    },
    {
      "name": "screenshot_action",
      "title": "Screenshot Action",
      "description": "Select the screen area for OCR and call the command ",
      "icon": "icon.png",
      "mode": "no-view",
      "private": true,
      "runInBackground": true,
      "commandType": "function_command",
      "showInCommandList": false,
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "preferences": [
        {
          "name": "copy_to_clipboard",
          "description": "Whether to copy the translated results to the clipboard.",
          "type": "checkbox",
          "required": false,
          "default": false,
          "title": "Copy to Clipboard"
        },
        {
          "name": "show_result_in_panel",
          "description": "Whether to show the translated results in a panel.",
          "type": "checkbox",
          "required": false,
          "default": true,
          "title": "Show Result in Panel"
        },
        {
          "name": "need_ocr",
          "description": "Whether to perform OCR before translation.",
          "type": "checkbox",
          "visibility": "hidden",
          "required": false,
          "default": false,
          "title": "Need OCR"
        },
        {
          "name": "preceding_context",
          "description": "Preceding Context",
          "type": "tags",
          "visibility": "hidden",
          "required": false,
          "default": [
            "screenshot_context|user_select_area_screenshot"
          ],
          "data": [
            {
              "title": "ScreenShot",
              "value": "screenshot_context|user_select_area_screenshot",
              "description": "Use select area screenshot"
            },
            {
              "title": "Browser active tab",
              "value": "browser_context|get_browser_current_tab_url",
              "description": "Capture the current active tab in the browser"
            }
          ],
          "title": "Preceding Context"
        },
        {
          "name": "window_mode",
          "type": "dropdown",
          "title": "Window Mode",
          "description": "Which window to open the command in",
          "default": "smart_bar",
          "dataProxy": "window|window_modes",
          "dataProxyConfig": {
            "needRefresh": false
          }
        },
        {
          "name": "bring_window_to_front",
          "type": "checkbox",
          "title": "Bring Window to Front",
          "description": "Whether to bring the window to front.",
          "default": false,
          "visibility": "hidden"
        },
        {
          "name": "post_command",
          "type": "command",
          "title": "Post Command",
          "default": "",
          "description": "The default command on the SmartBar. You can change it to any command you want.",
          "filter": {
            "recommend_extensions": [
              {
                "name": "writing_package",
                "expand": true
              }
            ]
          }
        }
      ]
    }
  ],
  "dependencies": {
    "@enconvo/api": "link:../../enconvo.nodejs/enconvo_api",
    "mp3-concat": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.31",
    "eslint": "^8.57.0",
    "prettier": "^2.8.8",
    "tsup": "^7.2.0",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "npm run lint --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --list-different \"**/*.ts\"",
    "build": "enconvo dev",
    "dev": "enconvo dev --dev"
  },
  "minAppVersion": "1.8.8"
}
